{
	"name": "smartmealplanner",
	"version": "0.1.0",
	"private": true,
	"packageManager": "pnpm@9.15.9",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "next build",
		"start": "next start",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"format": "biome format --write .",
		"ci:check": "biome ci .",
		"test": "vitest run",
		"test:watch": "vitest",
		"db:generate": "drizzle-kit generate",
		"db:seed": "NODE_EXTRA_CA_CERTS=${NODE_EXTRA_CA_CERTS:-/etc/ssl/certs/ca-certificates.crt} tsx scripts/seed.ts",
		"db:backfill-nutrition": "NODE_EXTRA_CA_CERTS=${NODE_EXTRA_CA_CERTS:-/etc/ssl/certs/ca-certificates.crt} tsx scripts/backfill-nutrition.ts"
	},
	"dependencies": {
		"@supabase/ssr": "^0.10.2",
		"@supabase/supabase-js": "^2.104.1",
		"@t3-oss/env-nextjs": "^0.11.1",
		"@tanstack/react-query": "^5.59.0",
		"clsx": "^2.1.1",
		"lucide-react": "^0.460.0",
		"next": "16.2.4",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"tailwind-merge": "^3.5.0",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"dotenv": "^17.4.2",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"tailwindcss": "^4",
		"tsx": "^4.21.0",
		"typescript": "^5",
		"vitest": "^2.1.4"
	}
}
