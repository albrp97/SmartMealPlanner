# Phase 0 placeholder.
# Copy to .env.local and fill in as you wire each external service.
# Validation lives in src/lib/env.ts — add a var there before adding it here.

# --- Supabase (Phase 1) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres URL used by Drizzle (Supabase pooled connection string).
DATABASE_URL=

# --- LLM (Phase 4) ---
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional fallback
OPENAI_API_KEY=

# --- Rate limiting (Phase 4) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Observability ---
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=

# Set to any non-empty value to skip env validation (CI builds, docker, etc.).
# SKIP_ENV_VALIDATION=1
